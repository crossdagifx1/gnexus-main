# Backend Environment Configuration (.env)
# Copy this file to your cPanel hosting at: /public_html/api/.env

# =====================================================
# DATABASE CONFIGURATION
# =====================================================
# Get these from: cPanel → MySQL Databases
DB_HOST=localhost
DB_NAME=your_cpanel_database_name
DB_USER=your_cpanel_database_user
DB_PASS=your_database_password

# =====================================================
# API KEYS
# =====================================================
# Get OpenRouter key from: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-YOUR-OPENROUTER-KEY-HERE

# Get OpenAI key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-YOUR-OPENAI-KEY-HERE

# Google OAuth
# Get from: https://console.cloud.google.com
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=https://gnexuset.com/auth/google/callback

# =====================================================
# SECURITY KEYS
# =====================================================
# Generate random 256-bit strings for these
# Use: https://randomkeygen.com/ or `openssl rand -hex 32`
JWT_SECRET=YOUR-RANDOM-256-BIT-STRING-HERE
CSRF_SECRET=YOUR-RANDOM-256-BIT-STRING-HERE

# =====================================================
# FILE UPLOAD CONFIGURATION
# =====================================================
# Absolute path to uploads directory on your server
# Example: /home/username/public_html/uploads
UPLOAD_DIR=/home/YOUR_CPANEL_USERNAME/public_html/uploads

# Maximum file size in bytes (10MB = 10485760)
MAX_FILE_SIZE=10485760

# Allowed image types
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp,image/gif

# =====================================================
# DOCKER CONFIGURATION (Optional - Code Execution)
# =====================================================
# Set to false if Docker not available on shared hosting
DOCKER_ENABLED=false

# If Docker is available (VPS/Dedicated only):
DOCKER_TIMEOUT=5
DOCKER_MEMORY_LIMIT=256m
DOCKER_CPU_LIMIT=0.5

# =====================================================
# APPLICATION SETTINGS
# =====================================================
# Your site URL (no trailing slash)
APP_URL=https://gnexuset.com

# Environment: production, development, or staging
APP_ENV=production

# Enable debug mode (set to false in production)
APP_DEBUG=false

# =====================================================
# RATE LIMITING
# =====================================================
# Requests per hour for various features
RATE_LIMIT_UPLOAD=20
RATE_LIMIT_CODE_EXEC=10
RATE_LIMIT_STT=30
RATE_LIMIT_TTS=50
RATE_LIMIT_SHARE=10

# =====================================================
# EMAIL CONFIGURATION (Optional - for notifications)
# =====================================================
MAIL_HOST=smtp.yourdomain.com
MAIL_PORT=587
MAIL_USERNAME=noreply@yourdomain.com
MAIL_PASSWORD=your-email-password
MAIL_FROM_ADDRESS=noreply@yourdomain.com
MAIL_FROM_NAME="G-Nexus AI"

# =====================================================
# SESSION CONFIGURATION
# =====================================================
SESSION_LIFETIME=120
SESSION_SECURE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=strict

# =====================================================
# LOGGING
# =====================================================
LOG_LEVEL=error
LOG_FILE=/home/YOUR_CPANEL_USERNAME/logs/app.log

# =====================================================
# CORS CONFIGURATION
# =====================================================
# Comma-separated list of allowed origins
CORS_ALLOWED_ORIGINS=https://gnexuset.com,https://www.gnexuset.com

# =====================================================
# NOTES
# =====================================================
# 1. Replace ALL placeholder values above
# 2. Keep this file secure - DO NOT commit to git
# 3. Use strong, unique values for all secrets
# 4. Update APP_URL with your actual domain
# 5. Set APP_DEBUG=false in production
# 6. DOCKER_ENABLED should be false on shared hosting
