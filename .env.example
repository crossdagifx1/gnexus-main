# Supabase Configuration
VITE_SUPABASE_PROJECT_ID="your-project-id"
VITE_SUPABASE_PUBLISHABLE_KEY="your-publishable-key"
VITE_SUPABASE_URL="https://your-project-id.supabase.co"

# Google Analytics (Optional)
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX
VITE_ANALYTICS_ENABLED=false

# Note: OpenRouter API Key is NOT stored here!
# For the AI chat to work, you need to set OPENROUTER_API_KEY in Supabase:
# 1. Go to https://openrouter.ai/keys to get your API key
# 2. In your Supabase project dashboard, go to Project Settings > Edge Functions
# 3. Add a secret: OPENROUTER_API_KEY = your_key_here
# See OPENROUTER_SETUP.md for detailed instructions
